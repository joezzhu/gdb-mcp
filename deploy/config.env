# ============================================================
# GDB MCP Server - 远程 Coredump 调试部署配置
# ============================================================
# 使用方法：
#   1. 复制此文件并修改为实际值
#   2. source config.env 或由 setup_remote.sh 自动加载
# ============================================================

# --- 安装配置 ---
# GDB MCP Server 安装目录（项目源码所在位置）
GDB_MCP_INSTALL_DIR=/opt/gdb-mcp

# Python 虚拟环境目录
GDB_MCP_VENV_DIR=/opt/gdb-mcp/venv

# --- 服务配置 ---
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
GDB_MCP_LOG_LEVEL=INFO

# GDB 可执行文件路径（留空则使用系统 PATH 中的 gdb）
# 如需调试 ARM 架构，可设为 /usr/bin/gdb-multiarch
GDB_PATH=

# --- SSE 模式配置（可选）---
# SSE 服务监听地址（0.0.0.0 表示所有接口）
GDB_MCP_SSE_HOST=0.0.0.0

# SSE 服务端口
GDB_MCP_SSE_PORT=8765

# --- 调试文件目录 ---
# 调试工作目录根路径
DEBUG_WORK_DIR=/data/debug

# Coredump 文件存放目录
COREDUMP_DIR=/data/debug/coredumps

# 可执行文件（带调试符号）目录
EXECUTABLE_DIR=/data/debug/executables

# Sysroot 目录（远程/容器环境的系统根）
SYSROOT_DIR=/data/debug/sysroot

# --- 系统配置（通常不需修改）---
# Python 最低版本要求
PYTHON_MIN_VERSION="3.10"
